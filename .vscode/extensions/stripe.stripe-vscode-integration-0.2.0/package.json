{
  "name": "stripe-vscode-integration",
  "displayName": "Sorbet",
  "description": "Ruby Intellisense for VS Code, powered by Sorbet.",
  "author": "#sorbet-extension",
  "license": "proprietary",
  "version": "0.2.0",
  "publisher": "stripe",
  "repository": {
    "type": "git",
    "url": "https://git.corp.stripe.com/stripe-internal/sorbet"
  },
  "engines": {
    "vscode": "^1.28.2"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "ruby",
    "stripe",
    "language-server"
  ],
  "activationEvents": [
    "onLanguage:ruby",
    "onCommand:extension.restartSorbetServer"
  ],
  "languages": [
    {
      "id": "ruby",
      "extensions": [
        ".rb",
        ".rbi",
        ".srb"
      ],
      "aliases": [
        "Ruby"
      ]
    }
  ],
  "main": "./out/extension",
  "contributes": {
    "commands": [
      {
        "command": "sorbet.restartServer",
        "title": "Restart Sorbet Server"
      },
      {
        "command": "sorbet.selectConfig",
        "title": "Select Sorbet Configuration"
      },
      {
        "command": "sorbet.enableSorbet",
        "title": "Enable Sorbet Server (beta)"
      },
      {
        "command": "sorbet.disableSorbet",
        "title": "Disable Sorbet Server, and revert to using Ruby Locate"
      },
      {
        "command": "sorbet.showOutput",
        "title": "Show Sorbet extention's output window."
      }
    ],
    "configuration": {
      "title": "Sorbet extension settings",
      "properties": {
        "sorbet.intellisenseProvider": {
          "type": [
            "string"
          ],
          "enum": [
            "none",
            "rubyLocate",
            "sorbet"
          ],
          "default": "none",
          "description": "Method to use for Intellisense (error squigglies, go to definition, etc.)"
        },
        "sorbet.sorbetPath": {
          "type": [
            "string"
          ],
          "default": "sorbet",
          "description": "Path to the Sorbet executable."
        },
        "sorbet.devSorbetPath": {
          "type": [
            "string"
          ],
          "description": "Path to the (development) Sorbet executable.",
          "default": "~/stripe/sorbet/bazel-bin/main/sorbet"
        },
        "sorbet.logLevel": {
          "type": [
            "number"
          ],
          "enum": [
            0,
            1,
            2
          ],
          "default": 0,
          "description": "Sorbet's log level (higher = more verbose)"
        },
        "sorbet.devLogLevel": {
          "type": [
            "number"
          ],
          "enum": [
            0,
            1,
            2
          ],
          "default": 1,
          "description": "Sorbet's log level in dev mode (higher = more verbose)"
        },
        "sorbet.extraArgs": {
          "type": [
            "array"
          ],
          "default": [],
          "description": "Extra CLI arguments to pass to Sorbet"
        },
        "sorbet.devExtraArgs": {
          "type": [
            "array"
          ],
          "default": [],
          "description": "Extra CLI arguments to pass to dev Sorbet"
        },
        "sorbet.runWith": {
          "type": [
            "array"
          ],
          "default": [],
          "description": "Passes sorbetPath and arguments to this executable, if specified. Useful for wrapping Sorbet."
        },
        "sorbet.disableRubyLocateInSorbetMode": {
          "type": [
            "boolean"
          ],
          "default": false,
          "description": "When in Sorbet mode, do not use Ruby locate to fill in functionality gaps."
        },
        "sorbet.useDevelopmentSorbet": {
          "type": [
            "boolean"
          ],
          "default": false,
          "description": "Whether to use the development version of Sorbet."
        },
        "sorbet.revealOutputOnError": {
          "type": [
            "boolean"
          ],
          "default": false,
          "description": "If true, it shows the extension's output window whenever there is an error."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./src",
    "watch": "tsc -w -p ./src",
    "lint": "./node_modules/eslint/bin/eslint.js --ext .ts ./src",
    "prettier": "./node_modules/.bin/prettier --write 'src/**/*.ts'",
    "test": "npm run compile && node ./node_modules/vscode/bin/test"
  },
  "dependencies": {
    "async": "^2.3.0",
    "elegant-spinner": "^2.0.0",
    "lodash": "^4.17.3",
    "minimatch": "^3.0.3",
    "ruby-method-locate": "*",
    "vscode-languageclient": "^4.1.3"
  },
  "devDependencies": {
    "@types/elegant-spinner": "^1.0.0",
    "@types/mocha": "^2.2.48",
    "@types/node": "^6.0.101",
    "@types/sinon": "^4.3.0",
    "eslint": "^4.14.0",
    "eslint-config-prettier": "^2.9.0",
    "eslint-config-stripe": "^1.2.0",
    "eslint-plugin-eslint-comments": "^2.0.2",
    "eslint-plugin-import": "^2.8.0",
    "eslint-plugin-jsx-a11y": "^6.0.3",
    "eslint-plugin-prettier": "^2.4.0",
    "power-assert": "^1.2.0",
    "prettier": "^1.9.2",
    "sinon": "^2.0.0-pre.2",
    "typescript": "^3.4",
    "@typescript-eslint/parser": "1.6.0",
    "vsce": "^1.51.1",
    "vscode": "^1.1.21"
  }
}
